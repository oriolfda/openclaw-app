<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="4dp">

    <LinearLayout
        android:id="@+id/audioBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_bot_ember"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/audioPlayButton"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@android:color/transparent"
                android:contentDescription="Play"
                android:src="@drawable/ic_play_min" />

            <TextView
                android:id="@+id/audioWaveText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="▁▂▃▄▅▆▇▆▅▄▃▂▁"
                android:textColor="#C7CDD8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/audioDurationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0:00"
                android:textColor="#D1D5DB"
                android:textSize="12sp" />

            <ImageButton
                android:id="@+id/audioTranscribeButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Transcribe"
                android:src="@android:drawable/ic_menu_edit"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/audioTranscriptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#1F2937"
            android:padding="8dp"
            android:textColor="#E5E7EB"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>

    <Space
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />

</LinearLayout>
